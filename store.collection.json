									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Response time is less than 1000ms\", function () {",
									"    pm.expect(pm.response.responseTime).to.be.below(1000);",
									"});",
									"pm.test(\"Content-Type is JSON\", function () {",
									"    pm.response.to.have.header(\"Content-Type\");",
									"    pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\");",
									"});",
									"pm.test(\"Products list has expected schema\", function () {",
									"    const products = pm.response.json();",
									"    pm.expect(products).to.be.an(\"array\").that.is.not.empty;",
									"    products.forEach((product) => {",
									"        pm.expect(product).to.include.keys(\"id\", \"name\", \"price\", \"sku\", \"description\");",
									"        pm.expect(product.id).to.be.a(\"number\");",
									"        pm.expect(product.name).to.be.a(\"string\");",
									"        pm.expect(product.price).to.be.a(\"number\");",
									"    });",
									"});"
								],
								"type": "text/javascript"
							}
